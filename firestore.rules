
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHITFUND PRO SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a strict Administrative Access model using Database-Backed Access Control (DBAC).
     * Access to business-critical data (Members, Payments, Chit Rounds) is restricted exclusively to 
     * users whose UIDs are present in the 'roles_admin' collection.
     * 
     * DATA STRUCTURE:
     * - /roles_admin/{uid}: Map of administrative users.
     * - /members/{memberId}: Detailed records of chit fund participants.
     * - /payments/{paymentId}: Transaction history for member contributions.
     * - /chitRounds/{roundId}: Historical data of completed auction rounds and winners.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has an entry in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines admin check with existence check for destructive operations. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Collection used for Database-Backed Access Control (DBAC).
     * @path /roles_admin/{adminId}
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Stores individual member details for the chit fund.
     */
    match /members/{memberId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == memberId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Records all monthly payments made by members.
     */
    match /payments/{paymentId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == paymentId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Stores details of completed chit fund rounds.
     */
    match /chitRounds/{roundId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == roundId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }
  }
}
