
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHITFUND PRO SECURITY RULES
     * 
     * UPDATED PHILOSOPHY:
     * Access is granted to any authenticated user. The strict UID-based 
     * 'roles_admin' check has been removed per requirements.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is authorized. Currently all signed-in users are authorized. */
    function isAdmin() {
      return isSignedIn();
    }

    /** @description Checks if user is authorized and resource exists. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Collection for admin roles (retained for structure).
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Stores individual member details for the chit fund.
     */
    match /members/{memberId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == memberId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Records all monthly payments made by members.
     */
    match /payments/{paymentId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == paymentId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Stores details of completed chit fund rounds.
     */
    match /chitRounds/{roundId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == roundId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }
  }
}
