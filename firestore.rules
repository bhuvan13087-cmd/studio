
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHITFUND PRO SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn();
    }

    match /members/{memberId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false; // Disallow deletion, use status=inactive
    }

    match /payments/{paymentId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /chitRounds/{roundId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /monthlyTargets/{targetId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Logs are immutable
    }

    match /monthLocks/{lockId} {
      allow get, list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if false; // Locks are usually replaced or deleted
    }

    match /cycles/{cycleId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /systemMetadata/{docId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow write: if false; // System metadata is strictly updated via server/admin
    }
  }
}
