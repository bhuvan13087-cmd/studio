rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHITFUND PRO SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a strict Administrative Access model using Database-Backed Access Control (DBAC).
     * Access to business-critical data (Members, Payments, Chit Rounds) is restricted exclusively to 
     * users whose UIDs are present in the 'roles_admin' collection.
     * 
     * DATA STRUCTURE:
     * - /roles_admin/{uid}: Map of administrative users.
     * - /members/{memberId}: Detailed records of chit fund participants.
     * - /payments/{paymentId}: Transaction history for member contributions.
     * - /chitRounds/{roundId}: Historical data of completed auction rounds and winners.
     * 
     * KEY SECURITY DECISIONS:
     * - Authorization Independence: Rules do not rely on ownership fields within data documents. 
     *   Instead, they perform an existence check on the 'roles_admin' collection.
     * - Secure Queryable Access Patterns: Because all data in the core collections share the 
     *   same admin-only posture, list operations are inherently safe for authorized users.
     * - Relational Integrity: On creation, documents must contain an 'id' field that matches 
     *   their Firestore document ID to ensure consistency between the path and the data.
     * 
     * PROTOTYPING MODE:
     * This ruleset prioritizes secure authorization over strict schema validation. Content 
     * fields are not type-checked to allow for rapid iteration on the data model.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has an entry in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines admin check with existence check for destructive operations. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Collection used for Database-Backed Access Control (DBAC).
     * @path /roles_admin/{adminId}
     * @allow (get) Any signed-in user can check their own admin status.
     * @deny (list) Non-admin users cannot list the directory of administrators.
     * @principle DBAC: Existence of a UID here grants site-wide administrative privileges.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Stores individual member details for the chit fund.
     * @path /members/{memberId}
     * @allow (create) Admin user creates a member document where data.id matches the path ID.
     * @deny (get) Anonymous or non-admin user attempts to view member details.
     * @principle Admin-Only Access: Business data is protected by global role check.
     */
    match /members/{memberId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == memberId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Records all monthly payments made by members.
     * @path /payments/{paymentId}
     * @allow (update) Admin updates payment status from 'pending' to 'paid'.
     * @deny (create) User attempts to create a payment record without being in the roles_admin collection.
     * @principle Relational Integrity: Ensures the internal ID remains immutable and matches the path.
     */
    match /payments/{paymentId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == paymentId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Stores details of completed chit fund rounds.
     * @path /chitRounds/{roundId}
     * @allow (list) Admin views the history of all completed rounds.
     * @deny (delete) Any user attempts to delete a round record without being an admin.
     * @principle Homogeneous Security: Entire collection shares a single security posture.
     */
    match /chitRounds/{roundId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == roundId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }
  }
}