
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHITFUND PRO SECURITY RULES
     * 
     * PHILOSOPHY:
     * Access is granted to any authenticated user. This supports the simplified
     * admin model where any logged-in user can manage members, payments, and rounds.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is authorized. Currently all signed-in users are authorized. */
    function isAdmin() {
      return isSignedIn();
    }

    /** @description Checks if user is authorized and resource exists. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Stores individual member details for the chit fund.
     */
    match /members/{memberId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Records all monthly payments made by members.
     */
    match /payments/{paymentId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Stores details of chit fund schemes and rounds.
     */
    match /chitRounds/{roundId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isExistingAdmin();
    }
  }
}
